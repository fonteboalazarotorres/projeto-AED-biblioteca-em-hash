{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Compilar projeto C++ completo",
            "type": "shell",
            "command": "/usr/bin/clang++",
            "args": [
                "-std=gnu++14",
                "-Wall",
                "-Wextra",
                "-pedantic",
                "-g",
                "${workspaceFolder}/main.cpp",
                "${workspaceFolder}/Biblioteca.cpp",
                "${workspaceFolder}/Loja.cpp",
                "-o",
                "${workspaceFolder}/main"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        }
    ]
}
